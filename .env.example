# Copy this file to `.env` and fill in real values. Never commit `.env`.

GEMINI_API_KEY=your_gemini_api_key_here

# Client-side API base URL (must start with VITE_ for Vite)
VITE_API_BASE_URL=https://cp0v4gw8-8080.asse.devtunnels.ms

# Optional: override upload route when your backend uses a different path
VITE_ESTIMATION_UPLOAD_PATH=/upload/estimationFile
# Optional: full upload URL (takes priority over base URL + path)
# VITE_ESTIMATION_UPLOAD_ENDPOINT=https://your-backend-base-url.example.com/service/estimation/upload/estimationFile

# Floor-plan vision analysis (OpenAI-compatible chat/completions)
# - xAI Grok: https://api.x.ai/v1 — use a model that supports images, e.g. grok-2-vision-1212
# - Groq (keys often start with gsk_): https://api.groq.com/openai/v1 — e.g. meta-llama/llama-4-scout-17b-16e-instruct
# If your key starts with gsk_, the app defaults to Groq URL + Llama 4 Scout unless you override below.
VITE_GROK_API_KEY=
VITE_GROK_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
VITE_GROK_BASE_URL=https://api.groq.com/openai/v1
